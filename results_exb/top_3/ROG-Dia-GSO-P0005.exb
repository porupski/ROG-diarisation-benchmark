    <tier id="COLLOQ_ROG-dialog-0007" speaker="ROG-dialog-0007" category="colloq" type="a" display-name="ROG-dialog-0007 [colloq]">
      <event start="T0-555" end="T2">Kaj zdej, </event>
      <event start="T2" end="T3-017">si kupla karte za na Sardinijo? </event>
      <event start="T5-403" end="T6">Ja, pa sej je čist enostavno. </event>
      <event start="T6" end="T7">Tm greš na uno spletno str@n od Rajenera, </event>
      <event start="T7" end="T8">puhledaš datume, </event>
      <event start="T8" end="T22">puhledaš cene </event>
      <event start="T22" end="T12-533">in puol si zbjereš. </event>
      <event start="T12-533" end="T9">Kulk cajta ... </event>
      <event start="T9" end="T16-579">kulk cajta bi bla tm? </event>
      <event start="T16-579" end="T10">Vječ cajta ku si, </event>
      <event start="T10" end="T18-133">bl poceni je. </event>
      <event start="T20-669" end="T13">Ja, </event>
      <event start="T13" end="T14">ti bi rada sam, </event>
      <event start="T14" end="T21">da ti drugi zrihtaju </event>
      <event start="T21" end="T23-316">pa da ti hrješ. </event>
      <event start="T26-411" end="T18">No, </event>
      <event start="T18" end="T19">ma tm si naluoži tisto aplikacijo od Rajener </event>
      <event start="T19" end="T20">in se prjav@š </event>
      <event start="T20" end="T32-282">in puol zbjereš karto. [zvok] </event>
      <event start="T34-931" end="T35-679">Ne, </event>
      <event start="T35-679" end="T36-904">morš met aplikacijo. </event>
      <event start="T37-794" end="T26">Ja, </event>
      <event start="T26" end="T40-45">ker pol maš shranjene te karte v aplikaciji. </event>
      <event start="T42-701" end="T296">Ja, </event>
      <event start="T296" end="T29">puol si jih pa še natisn@š, </event>
      <event start="T29" end="T30">č() če ti slučajn telefon crkne. </event>
      <event start="T30" end="T46-755">Ja. </event>
      <event start="T48-336" end="T33">Tm zbjereš, </event>
      <event start="T33" end="T34">pol se prjav@š, </event>
      <event start="T34" end="T35">prjav@š tiste usjebe, </event>
      <event start="T35" end="T53-776">ku grjejo. </event>
      <event start="T53-776" end="T36">Pa mor bit prov napisano. </event>
      <event start="T36" end="T56-595">Morjo bit vse črke prov. </event>
      <event start="T58-838" end="T37">Lohku eee z doplačil@m, </event>
      <event start="T37" end="T38">misl@m, da je desjet evru, </event>
      <event start="T38" end="T66-083">da zamenjaš eee naslov eee naslovnika karte. </event>
      <event start="T66-93" end="T39">Ja, </event>
      <event start="T39" end="T68-851">in pol s kartico plačaš. </event>
      <event start="T69-978" end="T72-147">Kartico j@maš za plačat? </event>
      <event start="T72-636" end="T73-12">Bančno? </event>
      <event start="T73-508" end="T73-944">A j@maš? </event>
      <event start="T75-105" end="T41">A no, </event>
      <event start="T41" end="T75-957">tistu j@maš. </event>
      <event start="T75-957" end="T78-046">No, in pol ko plačaš ... </event>
      <event start="T78-046" end="T242">puol pa hr@š nazaj v aplikacijo </event>
      <event start="T242" end="T81-743">in nardiš tisti ček in. </event>
      <event start="T82-496" end="T44">Ne? </event>
      <event start="T44" end="T45">In tm ti piše puol, </event>
      <event start="T45" end="T121">ob kulki uri grješ </event>
      <event start="T121" end="T46">in kdaj pristaneš. </event>
      <event start="T46" end="T88-976">In številko leta. </event>
      <event start="T88-976" end="T90-502">Pa za ... </event>
      <event start="T92-364" end="T50">Ja, no, </event>
      <event start="T50" end="T95-011">pa sej sss čm ti puvedat pa te navad@t. </event>
      <event start="T95-487" end="T120">Pa kaj b() </event>
      <event start="T120" end="T97-797">ki buste pa parkirali? </event>
      <event start="T98-887" end="T51">Ja, </event>
      <event start="T51" end="T100-809">avto na letališči? </event>
      <event start="T102-91" end="T105-010">Ma na, pa spet. </event>
      <event start="T105-010" end="T106-675">Pa tm rezervirejte tisto. </event>
      <event start="T107-182" end="T53">Ja, </event>
      <event start="T53" end="T112-081">sam morš met eee tab@lco, registracijo </event>
      <event start="T112-081" end="T116-436">in pol tm daš od kdaj do kdaj, kir datum in uro. </event>
      <event start="T117-061" end="T283">In pol tm p@stiš </event>
      <event start="T283" end="T120-101">in te že senzor zazna tab@lco, </event>
      <event start="T120-101" end="T120-7">ja. </event>
      <event start="T120-7" end="T54">Ja, </event>
      <event start="T54" end="T121-687">in nč ne rab@š. </event>
      <event start="T122-951" end="T57">No, </event>
      <event start="T57" end="T125-123">in ti je čist enostavno ke prid@t. </event>
      <event start="T126-027" end="T127-573">A no, sej smo šle zadnič. </event>
      <event start="T127-573" end="T129-229">Na pregled. </event>
      <event start="T129-229" end="T130-94">No, </event>
      <event start="T130-94" end="T61">in ko uste pršle nazaj, </event>
      <event start="T61" end="T284">se vsedeš v avto </event>
      <event start="T284" end="T134-639">in hr@š domov. </event>
      <event start="T137-504" end="T139-426">Sej buš počivala na letali. </event>
      <event start="T139-931" end="T65">Kuk cajta se uste pelali? </event>
      <event start="T65" end="T66">Dve uri? </event>
      <event start="T66" end="T67">Kulk smo se mi pelali? </event>
      <event start="T67" end="T143-902">Tri? </event>
      <event start="T143-902" end="T68">Dvej, </event>
      <event start="T68" end="T69">menda, </event>
      <event start="T69" end="T145-608">ne vem. </event>
      <event start="T147-075" end="T70">Na karti bo pisalu. </event>
      <event start="T70" end="T71">Kdaj je vzlet </event>
      <event start="T71" end="T150-099">in kdaj je pristanek. </event>
      <event start="T151-669" end="T72">Ja, </event>
      <event start="T72" end="T154-954">sej zatu si muorš naruo() naluožt tisto aplikacijo. </event>
      <event start="T155-796" end="T73">Ja, kaj pa </event>
      <event start="T73" end="T297">eee </event>
      <event start="T297" end="T159-028">hotel? </event>
      <event start="T159-028" end="T160-472">A ne boste v hoteli? </event>
      <event start="T160-472" end="T161-106">Ki pa boste? </event>
      <event start="T161-998" end="T163-895">A hmečki turizem bo? </event>
      <event start="T163-895" end="T165-350">Kaj z zajtrkom? </event>
      <event start="T166-285" end="T74">Aja? </event>
      <event start="T74" end="T167-803">Z zajtrkom? </event>
      <event start="T168-199" end="T169-249">Ma brez večirje? </event>
      <event start="T170-636" end="T171-47">Aja, večirja. </event>
      <event start="T171-47" end="T173-059">A uste šli kam drgam? </event>
      <event start="T175-607" end="T177-017">V kirmu kraji pa j@? </event>
      <event start="T178-395" end="T179-84">[smeh] </event>
      <event start="T181-733" end="T182-666">Ja, super. </event>
      <event start="T182-666" end="T183-906">Js bi šla tut taku. </event>
      <event start="T185-872" end="T186-625">Ja. </event>
      <event start="T189-13" end="T83">Ja, </event>
      <event start="T83" end="T189-841">no, </event>
      <event start="T189-841" end="T192-035">ma sej tut tu preko Bukinga reš l@hku, ne? </event>
      <event start="T192-462" end="T244">Tut tu morš imeti aplikacijo </event>
      <event start="T244" end="T195-428">pa se registrir@t. </event>
      <event start="T196-431" end="T86">Ne, </event>
      <event start="T86" end="T198-341">pa si zbereš, kar č@š. </event>
      <event start="T201-508" end="T245">Mor@š met aplikacijo </event>
      <event start="T245" end="T89">pa si rezerviraš Buking, </event>
      <event start="T89" end="T90">pa sej tm maš guor tut apartmaje in bungalove menda in hotelov, kmečke turizme, </event>
      <event start="T90" end="T209-453">menda je vse guor. </event>
      <event start="T212-783" end="T214-062">[glas] Ja. </event>
      <event start="T216-064" end="T93">Ja, lepu. </event>
      <event start="T93" end="T218-39">Kaj pa za potovalko? </event>
      <event start="T218-39" end="T219-393">Kuf@r? </event>
      <event start="T220-038" end="T222-237">Mourš puhledat une mire, ku gre na letal. </event>
      <event start="T222-237" end="T224-568">Ne boš nč uzela? </event>
      <event start="T227-374" end="T227-945">Ja. </event>
      <event start="T227-945" end="T94">Ne vem, </event>
      <event start="T94" end="T285">odvisno, kdaj hjreš, </event>
      <event start="T285" end="T230-536">kašno vreme bo. </event>
      <event start="T230-974" end="T95">Kupalke nesi, </event>
      <event start="T95" end="T233-003">m@rda buoš šla se kuop@t. </event>
      <event start="T234-164" end="T234-882">Ja. </event>
      <event start="T236-333" end="T237-871">Hreste prezgudi. </event>
      <event start="T240-241" end="T241-892">Ja, lej. </event>
      <event start="T241-892" end="T243-700">Pol buste pa raziskovali okuli </event>
      <event start="T243-700" end="T245-127">pa na izlete boste šli. </event>
      <event start="T246-422" end="T98">Misl@m, da je dimenzije štir, </event>
      <event start="T98" end="T99">eee ku(), ne, </event>
      <event start="T99" end="T100">rudzah je štjirdeset, pjed@s@t, dvajst, </event>
      <event start="T100" end="T252-894">ne? </event>
      <event start="T253-52" end="T101">Kuf@r je pa, </event>
      <event start="T101" end="T103">piše na aplikaciji od Rajenera, </event>
      <event start="T103" end="T258-191">murš puhljedat, kulk gre l@hku. </event>
      <event start="T258-801" end="T259-132">Ker če ... </event>
      <event start="T259-92" end="T260-941">Ja, tudi. </event>
      <event start="T260-941" end="T105">Ker če boš na pršla na letališče, </event>
      <event start="T105" end="T106">mor@š, </event>
      <event start="T106" end="T265-174">tm je en tak pano, </event>
      <event start="T265-174" end="T246">pa nuotr je ohrajenu, kaš@n eee kuf@r gre nuoter. </event>
      <event start="T246" end="T107">Če je pre() prevel@k, </event>
      <event start="T107" end="T108">lohk plačaš tut pjedes@t evrov, </event>
      <event start="T108" end="T271-182">veš? </event>
      <event start="T271-725" end="T272-324">Ja, ja. </event>
      <event start="T273-188" end="T275-063">Te lohku tm kr ustavjo. </event>
      <event start="T275-063" end="T275-692">Ja. </event>
      <event start="T275-692" end="T110">Zatu morju b@t standardne mjere. </event>
      <event start="T110" end="T279-907">Tku ku piše tm, na aplikaciji. </event>
      <event start="T283-793" end="T284-027">Ja. </event>
      <event start="T284-027" end="T285-21">Pejt puhled@t. </event>
      <event start="T285-21" end="T112">Po moje da j@maju v tej eee, </event>
      <event start="T112" end="T288-868">kaj je una trhovina? </event>
      <event start="T290-093" end="T290-684">Beksendmor. </event>
      <event start="T290-684" end="T292-129">In uni napis guor. </event>
      <event start="T293-437" end="T114">Ja, da si prlep@š huor, </event>
      <event start="T114" end="T295-442">čihau kuf@r je. </event>
      <event start="T295-442" end="T115">Če se zgubi, </event>
      <event start="T115" end="T297-823">da ti ha pol pošlejo. </event>
      <event start="T298-746" end="T299-861">Etiketo. </event>
      <event start="T302-193" end="T304-443">Marjele ne smeš uzjet s sabo. </event>
      <event start="T305-545" end="T306-795">Na l() eee na </event>
      <event start="T306-795" end="T308-39">u ruz@k ne sme b@t. </event>
      <event start="T308-39" end="T309-99">Sam v kuf@r. </event>
      <event start="T310-982" end="T312-821">Pa vuode tut ne smeš nest čjez. </event>
      <event start="T313-459" end="T314-248">Ja. </event>
      <event start="T314-248" end="T253">Sam sendviče. </event>
      <event start="T253" end="T318-274">Tisto vuodo boš pa kupla puol na letališči, </event>
      <event start="T318-274" end="T320-407">ko boš šla že skuzi kontrolo. </event>
      <event start="T324-765" end="T326-399">Eee mor@š met eee </event>
      <event start="T326-399" end="T247">pauerbenk morš met pr sjebi </event>
      <event start="T247" end="T330-54">pa povnivc morš met pr sjebi u rudzahi. </event>
      <event start="T330-54" end="T332-202">Tu ne smej bit noter u kufri. </event>
      <event start="T332-997" end="T333-485">Ne, </event>
      <event start="T333-485" end="T254">tu morš met pr sjebi, </event>
      <event start="T254" end="T122">in ku buš šla skus kontrolo, </event>
      <event start="T122" end="T337-61">morš tu vse d@t ven. </event>
      <event start="T338-364" end="T340-535">Na na tekoči trak. </event>
      <event start="T341-399" end="T343-048">In pas tudi. </event>
      <event start="T343-796" end="T344-368">Ja. </event>
      <event start="T344-923" end="T345-714">Ja. </event>
      <event start="T347-003" end="T349-943">Vse boš dala v tiste plastične eee gajbce. </event>
      <event start="T349-943" end="T255">K vse poprekontrolirajo, </event>
      <event start="T255" end="T353-177">ko gre skuz rentgen. </event>
      <event start="T355-804" end="T358-828">Tistu je do stu mililitrov maš lohku s sabo. </event>
      <event start="T360-015" end="T360-949">Več pa ne. </event>
      <event start="T361-753" end="T299">Ja, </event>
      <event start="T299" end="T363-013">večja pa v kuf@r, ja. </event>
      <event start="T364-46" end="T364-967">Ja. </event>
      <event start="T367-86" end="T286">Majh@n, šulski, </event>
      <event start="T286" end="T370-694">da bo šel pod stol od aviona. </event>
      <event start="T372-469" end="T375-671">Pod nuo() pr pr nuohah spuodi ga buš speštala. </event>
      <event start="T376-491" end="T377-213">Ja. </event>
      <event start="T378-683" end="T380-775">Pijačo si lohku kupš tut na letali, </event>
      <event start="T380-775" end="T381-536">pa je draha. </event>
      <event start="T382-031" end="T382-543">Ja. </event>
      <event start="T382-543" end="T383-645">Parfume maju guor. </event>
      <event start="T384-231" end="T386-946">Ja, hrano majo tut guor, kufe. </event>
      <event start="T386-946" end="T389-2">Sam je kr drago. </event>
      <event start="T391-297" end="T393-056">Ja, al pa puol. </event>
      <event start="T393-056" end="T394-237">Ku pristan@š. </event>
      <event start="T399-341" end="T401-133">Ma odvisnu. </event>
      <event start="T401-133" end="T125">Odvisnu, </event>
      <event start="T125" end="T404-386">kulku cajta rabijo, da razložijo letalo. </event>
      <event start="T406-696" end="T300">Ja, </event>
      <event start="T300" end="T407-768">tudi, ja. </event>
