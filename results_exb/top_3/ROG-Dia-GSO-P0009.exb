    <tier id="COLLOQ_ROG-dialog-0015" speaker="ROG-dialog-0015" category="colloq" type="a" display-name="ROG-dialog-0015 [colloq]">
      <event start="T1-407" end="T1">Ki() eee ki() </event>
      <event start="T1" end="T3-606">kje sma zdaj ostala? </event>
      <event start="T4-688" end="T5-234">Pr ovčkah, </event>
      <event start="T5-234" end="T5-582">ja. </event>
      <event start="T6-575" end="T2">A veš, </event>
      <event start="T2" end="T3">kaj imam? </event>
      <event start="T3" end="T9-312">Zdej, zdej sem eee ... </event>
      <event start="T9-312" end="T11-283">Ta prvu sem štiri kupu. </event>
      <event start="T11-798" end="T16-599">Pred štirimi leti, da bojo mi tisto v() vrt gor popasle, </event>
      <event start="T16-599" end="T17-152">ne. </event>
      <event start="T17-152" end="T18-844">Da bojo vrt popasle. </event>
      <event start="T18-844" end="T21-301">Seveda pa js p() pa ljubitelj sem tega, </event>
      <event start="T21-301" end="T22-244">k js sem mel, </event>
      <event start="T22-244" end="T23-484">se spomniš dobru, </event>
      <event start="T24-019" end="T26-017">pred sedmimi leti petindevetdeset plemenskih že ovc, </event>
      <event start="T26-017" end="T28-382">ne. </event>
      <event start="T28-382" end="T4">Ne, </event>
      <event start="T4" end="T5">ken potem sem pa s mislu, </event>
      <event start="T5" end="T31-558">bom to, </event>
      <event start="T31-558" end="T6">de mi vrt popase, </event>
      <event start="T6" end="T8">pa bom jes to potem ve() eee v jesen poklal, </event>
      <event start="T8" end="T7">pa v skrinju pa kašnemu prijatelju še, </event>
      <event start="T7" end="T39-875">ne? </event>
      <event start="T40-283" end="T41-868">Pa m spet drugu ljetu to ... </event>
      <event start="T42-428" end="T44-147">o() o() spet ... </event>
      <event start="T44-147" end="T9">Tako, </event>
      <event start="T9" end="T10">ja, ja, </event>
      <event start="T10" end="T46-604">tako. </event>
      <event start="T46-604" end="T11">Ne, </event>
      <event start="T11" end="T12">k() in iz tega ni blo pa potem nič. </event>
      <event start="T12" end="T13">Pa pršla jesen, </event>
      <event start="T13" end="T53-42">kovčke so ble stare sedem, kosem mescov. </event>
      <event start="T53-42" end="T56-345">So mele vse prek št@rdeset kil, </event>
      <event start="T56-345" end="T14">so so mele že ž() ž() žive teže, </event>
      <event start="T14" end="T58-556">sem rjeku, ja pa to. </event>
      <event start="T58-556" end="T15">Pa za mene bi p() </event>
      <event start="T15" end="T16">osebno bi jest to rabu, </event>
      <event start="T16" end="T64-124">ne. </event>
      <event start="T64-56" end="T17">Tako ki() kilažo, </event>
      <event start="T17" end="T18">ne. </event>
      <event start="T18" end="T19">Pa za prodajo pa to več ni, </event>
      <event start="T19" end="T68-480">ne. </event>
      <event start="T68-480" end="T20">In in tak so ostale, </event>
      <event start="T20" end="T21">ne. </event>
      <event start="T21" end="T71-753">In tak so ostale. </event>
      <event start="T72-427" end="T73-648">Potem pa še ... </event>
      <event start="T75-305" end="T76-605">Kovna sem mel. </event>
      <event start="T77-073" end="T22">Tud, </event>
      <event start="T22" end="T77-957">ja. </event>
      <event start="T79-673" end="T23">Tako, </event>
      <event start="T23" end="T80-418">ja. </event>
      <event start="T80-973" end="T83-6">[smeh] Potem so ble pa mlade. </event>
      <event start="T83-6" end="T85-713">Potem sem pa ... </event>
      <event start="T85-713" end="T25">Seveda, </event>
      <event start="T25" end="T24">k jaz s() mam to, </event>
      <event start="T24" end="T89-386">sem mel od od od mlad() mladih nog sem js to rad, </event>
      <event start="T89-386" end="T26">ne. </event>
      <event start="T26" end="T27">Ja, </event>
      <event start="T27" end="T28">tako, </event>
      <event start="T28" end="T29">življenje, </event>
      <event start="T29" end="T94-029">ja. </event>
      <event start="T94-029" end="T31">Eee </event>
      <event start="T31" end="T30">ne, </event>
      <event start="T30" end="T100-028">in potem sem pa še kupu še potem še po dve, po tri </event>
      <event start="T100-028" end="T32">in sem prišel pol na deset, </event>
      <event start="T32" end="T102-04">ne. </event>
      <event start="T102-04" end="T33">Na deset, </event>
      <event start="T33" end="T103-724">ne. </event>
      <event start="T103-724" end="T108-448">Zdej sem pa eee kupu jih še pet. </event>
      <event start="T108-448" end="T111-987">Tak da lahko uvelavlam subvencijo za za ... </event>
      <event start="T111-987" end="T115-716">k morem pa nejmenj št@rnajst jih met o() odrasli ovc. </event>
      <event start="T116-303" end="T34">Te da lahko uvelavlam subvencijo, </event>
      <event start="T34" end="T118-673">ne. </event>
      <event start="T119-676" end="T120-421">Ja. </event>
      <event start="T120-421" end="T121-415">No ... </event>
      <event start="T121-415" end="T36">Zej me pa še en prjatl klical, </event>
      <event start="T36" end="T37">je reku, </event>
      <event start="T37" end="T38">pravi, </event>
      <event start="T38" end="T39">je reku: </event>
      <event start="T39" end="T40">"Lej, </event>
      <event start="T40" end="T127-677">tako eno ljepo mam pisano." </event>
      <event start="T127-677" end="T41">Je reku: </event>
      <event start="T41" end="T42">"Prid si pogleat," </event>
      <event start="T42" end="T43">pa, pa bi jo vz() vzel, </event>
      <event start="T43" end="T44">ne. </event>
      <event start="T44" end="T45">Mislim, </event>
      <event start="T45" end="T131-517">vzel ... </event>
      <event start="T131-517" end="T133-193">[nerazumljivo] ja ja. </event>
      <event start="T133-193" end="T46">Samo eno, </event>
      <event start="T46" end="T133-859">ne. </event>
