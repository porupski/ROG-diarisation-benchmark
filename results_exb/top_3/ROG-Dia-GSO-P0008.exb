      <event start="T336" end="T1185-65">Bre() brez ovitka je še hujše. </event>
      <event start="T1185-65" end="T1187-902">[smeh] </event>
      <event start="T1191-287" end="T339">Ja ne vem, zakaj je tako velik. [zvok] </event>
