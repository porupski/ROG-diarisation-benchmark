    <tier id="COLLOQ_ROG-dialog-0013" speaker="ROG-dialog-0013" category="colloq" type="a" display-name="ROG-dialog-0013 [colloq]">
      <event start="T0-535" end="T1-682">Okej. </event>
      <event start="T2-655" end="T1">No, </event>
      <event start="T1" end="T4-181">kakšno je blo tvoje kosilo? </event>
      <event start="T6-67" end="T7-708">[smeh] </event>
      <event start="T8-464" end="T8-752">Ja? </event>
      <event start="T23-06" end="T24-467">Ja, ja. </event>
      <event start="T25-872" end="T5">Moja je bla bolj tko. </event>
      <event start="T5" end="T209">Lah bi mela kej več salame. </event>
      <event start="T209" end="T30-435">Eem ... </event>
      <event start="T30-435" end="T32-072">[nerazumljivo] </event>
      <event start="T32-072" end="T6">Kaj je že blo gor? </event>
      <event start="T6" end="T7">Salama, čebula, sir pa en jajc. </event>
      <event start="T7" end="T8">Tist jajc je bil tko. </event>
      <event start="T8" end="T38-459">Mal brezveze. </event>
      <event start="T40-020" end="T40-743">[smeh] </event>
      <event start="T40-743" end="T44-114">[smeh] Ja če je bil po moje spečen zravn s pico. </event>
      <event start="T44-114" end="T213">Ampak </event>
      <event start="T213" end="T9">ja no. </event>
      <event start="T9" end="T178">Mal je mal je blo, </event>
      <event start="T178" end="T49-351">več salame bi rabu. </event>
      <event start="T49-351" end="T10">Nja. </event>
      <event start="T10" end="T52-002">Pa šunka namest salame v bistvu. </event>
      <event start="T53-995" end="T231">V bistvu bi mogu sam drugo pico naročit, </event>
      <event start="T231" end="T56-011">ja. </event>
      <event start="T57-229" end="T58-529">[smeh] </event>
      <event start="T62-088" end="T211">Aaa. </event>
      <event start="T211" end="T212">Tko na ... </event>
      <event start="T212" end="T11">ne. </event>
      <event start="T11" end="T66-38">Na prbližno. </event>
      <event start="T69-483" end="T353">A </event>
      <event start="T353" end="T70-545">saj res. </event>
      <event start="T71-528" end="T352">Saj res, </event>
      <event start="T352" end="T73-006">ja. </event>
      <event start="T86-789" end="T215">To je cel pojnt pice, </event>
      <event start="T215" end="T15">a ni? </event>
      <event start="T15" end="T90-605">Tista omaka. </event>
      <event start="T101-816" end="T102-502">Ja. </event>
      <event start="T102-502" end="T103-560">Ne em, </event>
      <event start="T103-560" end="T104-897">moja je bla domača. </event>
      <event start="T111-364" end="T22">No. </event>
      <event start="T22" end="T114-372">Me zanima, kakšna je njihova kebab pica. </event>
      <event start="T114-372" end="T116-554">K sem jo enkrat v Fokulusu naroču. </event>
      <event start="T116-554" end="T23">Sem dobu gor tok une omake. </event>
      <event start="T23" end="T119-639">Ta bele. </event>
      <event start="T119-639" end="T122-434">To to sem sam omako jedu. </event>
      <event start="T122-434" end="T232">To to to se samo, </event>
      <event start="T232" end="T218">to je bla pica, testo pa omaka, </event>
      <event start="T218" end="T24">dets, </event>
      <event start="T24" end="T128-084">to to vse, kar si mel gor v bistvu. </event>
      <event start="T128-084" end="T25">No, </event>
      <event start="T25" end="T180">sej so ble še druge zadeve, ampak [smeh] </event>
      <event start="T180" end="T131-956">omaka je prevladala. </event>
      <event start="T135-574" end="T355">Oja, </event>
      <event start="T355" end="T136-912">definitivno. </event>
      <event start="T136-912" end="T181">Tko da če greš v Fokulus, </event>
      <event start="T181" end="T220">nareč() </event>
      <event start="T220" end="T182">naroč kebab pico. </event>
      <event start="T182" end="T141-927">Ampak tko s četrt omake. </event>
      <event start="T144-891" end="T26">Ja lej. </event>
      <event start="T26" end="T147-875">Smo vseen iz osredneslovenske regije. </event>
      <event start="T153-574" end="T28">Ja lej. [glas] </event>
      <event start="T28" end="T222">Lah greš pa v Makdonalds, </event>
      <event start="T222" end="T29">ne, </event>
      <event start="T29" end="T30">teh je tud dost, </event>
      <event start="T30" end="T159-384">pa zej na novo K@F@C@. </event>
      <event start="T161-547" end="T162-589">Nisem še bil. </event>
      <event start="T171-252" end="T174-487">[smeh] [nerazumljivo] </event>
      <event start="T182-702" end="T184-619">[smeh] Ja. </event>
      <event start="T196-557" end="T35">Js sem bil v onmu zraven Vupa </event>
      <event start="T35" end="T201-126">in s() povsem polno otrok not. [smeh] </event>
      <event start="T201-126" end="T36">Ampak ja, ne, </event>
      <event start="T36" end="T204-44">tud js se nisem neki velik najedu. </event>
      <event start="T204-44" end="T184">K ful šparajo s krompirjem, </event>
      <event start="T184" end="T37">ne vem, zakva, </event>
      <event start="T37" end="T38">to j itak [smeh] </event>
      <event start="T38" end="T209-587">pač kr neki jih stane. </event>
      <event start="T212-849" end="T40">Ne, </event>
      <event start="T40" end="T39">pa js sem burger naroču, </event>
      <event start="T39" end="T215-14">a ne. </event>
      <event start="T216-262" end="T41">In pol dobiš un mejh@n burger, </event>
      <event start="T41" end="T42">pol pa še mal krompirja </event>
      <event start="T42" end="T233">in sam debelo gledaš, </event>
      <event start="T233" end="T220-891">kva, zakva s to ... </event>
      <event start="T220-891" end="T222-696">Zakva se tle ... </event>
      <event start="T224-39" end="T229">Ja pa zakaj, </event>
      <event start="T229" end="T226-027">sej so ... </event>
      <event start="T229-923" end="T187">Ja dobr, </event>
      <event start="T187" end="T43">tist pa ... </event>
      <event start="T43" end="T44">tist sem pa v Španiji naroču </event>
      <event start="T44" end="T359">pa je blo tok zan@č, </event>
      <event start="T359" end="T237-167">najbolj brez d() okusa piščanc na svetu. </event>
      <event start="T237-167" end="T230">Eee </event>
      <event start="T230" end="T46">ja. </event>
      <event start="T46" end="T45">Tist je blo zan@č. </event>
      <event start="T45" end="T242-042">Pa še drag je bil. </event>
      <event start="T243-437" end="T244-170">Kr neki. </event>
      <event start="T247-582" end="T47">Ne. </event>
      <event start="T47" end="T251-081">Dražji je k Makdonalds v bistvu. </event>
      <event start="T254-158" end="T48">Ja. </event>
      <event start="T48" end="T256-772">Naslednja tema? </event>
      <event start="T257-953" end="T259-689">Tole hrano smo kr dobro obdelal. </event>
      <event start="T259-689" end="T260-448">[nerazumljivo] </event>
      <event start="T273-809" end="T275-141">Ja ja ... </event>
      <event start="T277-816" end="T279-117">Ja, </event>
      <event start="T279-117" end="T279-790">velika napaka v tvojem življenju. </event>
      <event start="T281-613" end="T284-169">O tem bomo govoril še dolgo. </event>
      <event start="T288-365" end="T289-843">Je kupu že enga? </event>
      <event start="T296-220" end="T298-684">Preveč siv je bil. </event>
      <event start="T300-915" end="T302-928">Kako je tisto modra barva? [smeh] </event>
      <event start="T304-386" end="T306-974">Tisto ni modra barva. [smeh] </event>
      <event start="T310-077" end="T56">Oja, </event>
      <event start="T56" end="T311-654">to pa je modro. </event>
      <event start="T311-654" end="T313-786">[smeh] </event>
      <event start="T313-786" end="T315-68">Tisto je črn. </event>
      <event start="T317-792" end="T57">Nja, </event>
      <event start="T57" end="T320-255">Midnajt P@rp@l pa ista barva. </event>
      <event start="T321-7" end="T237">O, </event>
      <event start="T237" end="T323-139">a je siv? </event>
      <event start="T338-745" end="T339-728">Mmm. </event>
      <event start="T346-099" end="T347-797">Pol tko mal kolor šifta, a? </event>
      <event start="T349-81" end="T351-348">[smeh] </event>
      <event start="T352-45" end="T354-265">Skrajna inovacija, prav@š? </event>
      <event start="T357-943" end="T359-491">Mmm. </event>
      <event start="T359-491" end="T61">Er pomen, da nima ventilatorja, </event>
      <event start="T61" end="T362-643">a ne? </event>
      <event start="T362-643" end="T366-935">[smeh] </event>
      <event start="T370-89" end="T371-576">Ja ja. </event>
      <event start="T373-054" end="T62">Zelo uporabna mašina, </event>
      <event start="T62" end="T375-404">moram rečt, ja. </event>
      <event start="T388-652" end="T389-853">Ja. </event>
      <event start="T403-914" end="T406-646">Mhm mhm. </event>
      <event start="T409-383" end="T411-067">Hvala bogu. </event>
      <event start="T411-067" end="T412-989">Tko mora bit. [smeh] </event>
      <event start="T412-989" end="T68">Če leptop ni tri centi debel, </event>
      <event start="T68" end="T416-667">a je sploh leptop? </event>
      <event start="T424-347" end="T243">A, </event>
      <event start="T243" end="T426-043">k jih noben ne uporablja itak. </event>
      <event start="T440-084" end="T441-067">Aaa. </event>
      <event start="T444-15" end="T444-665">Ja. </event>
      <event start="T449-809" end="T450-815">A se še pržge? </event>
      <event start="T452-647" end="T455-211">A baterija [smeh] kej drži? </event>
      <event start="T459-032" end="T73">Bi si mislu, </event>
      <event start="T73" end="T461-045">ja. </event>
      <event start="T468-785" end="T247">Ja, </event>
      <event start="T247" end="T470-442">ni idealno, no. </event>
      <event start="T492-391" end="T493-738">[smeh] </event>
      <event start="T514-451" end="T251">Pol je to zej [glas] modern </event>
      <event start="T251" end="T252">eem </event>
      <event start="T252" end="T520-715">tajprajtr v bistvu. </event>
      <event start="T520-715" end="T83">Vord še dela, </event>
      <event start="T83" end="T523-895">bi si mislu? </event>
      <event start="T525-591" end="T526-693">Beležnica? </event>
      <event start="T527-656" end="T528-502">No evo. </event>
      <event start="T528-502" end="T531-195">[smeh] Pa ga maš. </event>
      <event start="T544-466" end="T358">Ja, </event>
      <event start="T358" end="T546-318">bi si mislu. </event>
      <event start="T554-157" end="T90">Veš, </event>
      <event start="T90" end="T89">če bi bil Vindovs, </event>
      <event start="T89" end="T558-508">bi se povezal. </event>
      <event start="T562-126" end="T564-156">Jap. [smeh] </event>
      <event start="T564-156" end="T91">Mislim dva tisoč dvanajst, </event>
      <event start="T91" end="T92">kdaj je Vindovs deset prišel? </event>
      <event start="T92" end="T93">Dva tisoč petnajst? </event>
      <event start="T93" end="T571-312">To sploh ni tok stara Vindovs mašina pol. [smeh] </event>
      <event start="T574-97" end="T94">Pač eem ... </event>
      <event start="T94" end="T581-739">mami pa oči mata doma eee Vindovs deset na petnajst let starem računalniku </event>
      <event start="T581-739" end="T584-446">pa čist lepo dela. </event>
      <event start="T592-237" end="T96">Aja, </event>
      <event start="T96" end="T595-32">ja sam tko je ven izpadu iz ure al kaj? </event>
      <event start="T604-308" end="T605-918">Ja kok uporabno, </event>
      <event start="T605-918" end="T258">moram rečt, no, </event>
      <event start="T258" end="T98">super zadeva. [smeh] </event>
      <event start="T98" end="T609-967">Kojoj. </event>
      <event start="T615-666" end="T101">Ja ... </event>
      <event start="T101" end="T260">bi reku, da Eplova, </event>
      <event start="T260" end="T621-88">so že oni nekej nared@l, da zej ne dela. </event>
      <event start="T626-251" end="T627-472">Mhm mhm. </event>
      <event start="T633-825" end="T635-323">Kater? </event>
      <event start="T636-544" end="T637-765">Ja? </event>
      <event start="T639-996" end="T642-544">Ma hedfon džek? [smeh] </event>
      <event start="T643-903" end="T647-216">Cs nisi prepričan? </event>
      <event start="T649-249" end="T650-438">Ne em. </event>
      <event start="T653-408" end="T655-546">Dva? </event>
      <event start="T655-546" end="T105">[smeh] Dva. </event>
      <event start="T105" end="T660-096">Ja. </event>
      <event start="T660-096" end="T106">Ne morem si predstavljat, kako bi več k dva rabu, </event>
