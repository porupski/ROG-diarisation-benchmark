      <event start="T1024-446" end="T145">Ja glej. </event>
      <event start="T145" end="T146">Pač to je tak eem </event>
      <event start="T146" end="T319">eee </event>
      <event start="T319" end="T320">tak vmesni korak, </event>
      <event start="T320" end="T321">a ne, </event>
      <event start="T321" end="T1031-525">bomo rekli. </event>
      <event start="T1031-525" end="T322">Dokler o() ne pogruntajo, da je OLED lahko še svetel pa ne </event>
      <event start="T322" end="T323">nnn se ne zažge, </event>
      <event start="T323" end="T1037-734">a ne. </event>
      <event start="T1047-237" end="T148">Možno. </event>
      <event start="T148" end="T1049-409">Ne vem. </event>
      <event start="T1050-748" end="T1052-464">Ampak ja. </event>
