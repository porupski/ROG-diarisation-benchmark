      <event start="T35-966" end="T10">Eem </event>
      <event start="T10" end="T11">pa tam me je pol moj prijatelj pobral </event>
      <event start="T11" end="T442">in sem šla pol sm() smo šli z avtom do Zagreba. </event>
      <event start="T442" end="T43-813">[smeh] </event>
      <event start="T47-687" end="T48-133">Ja z ... </event>
      <event start="T48-133" end="T14">ja, ja, </event>
      <event start="T14" end="T13">z vlakom sem šla, </event>
      <event start="T13" end="T50-642">ja. </event>
      <event start="T51-553" end="T52-69">Ja. </event>
      <event start="T52-69" end="T15">No, </event>
      <event start="T15" end="T16">eem, </event>
      <event start="T16" end="T17">tako da sem en dan prej spakirala, </event>
      <event start="T17" end="T18">zaradi tega ker se prej nisem lotila pakirati, </event>
      <event start="T18" end="T60-812">zaradi tega ker sem malo neumna. </event>
      <event start="T60-812" end="T19">Ampak okej, </event>
      <event start="T19" end="T64-389">to bomo pustili za sabo. </event>
      <event start="T64-389" end="T20">Eem, </event>
