    </tier>
    <tier id="TIE4" speaker="ROG-dialog-0049" category="norm" type="t" display-name="ROG-dialog-0049 [norm]">
      <event start="T7-327" end="T4">Eem, </event>
      <event start="T4" end="T5">ja, </event>
