      <event start="T446" end="T409-126">[smeh] </event>
      <event start="T415-201" end="T417-462">Aja, </event>
      <event start="T417-462" end="T447">[smeh] </event>
      <event start="T447" end="T418-65">tako se ne leti. </event>
      <event start="T418-65" end="T419-454">[smeh] </event>
      <event start="T419-454" end="T95">Tako se ne leti. </event>
      <event start="T95" end="T423-825">Leti se tako, da pristaneš </event>
      <event start="T423-825" end="T96">in si samo hvaležen, da si pristal, </event>
      <event start="T96" end="T97">ne pa začneš ploskati, </event>
      <event start="T97" end="T430-495">zaradi tega ker to je stvar, ko jo samo beli ljudje delajo. </event>
      <event start="T430-495" end="T433-295">In jaz nisem taka bela oseba. [smeh] </event>
      <event start="T437-429" end="T438-977">Eem. </event>
