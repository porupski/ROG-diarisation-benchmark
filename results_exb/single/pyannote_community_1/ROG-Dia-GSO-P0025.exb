    <tier id="COLLOQ_ROG-dialog-0048" speaker="ROG-dialog-0048" category="colloq" type="a" display-name="ROG-dialog-0048 [colloq]">
      <event start="T1-809" end="T2">Odkar s nazaj pršla, se še nisma čula. </event>
      <event start="T2" end="T3">T@k povej mi malo, k@k je blo kaj na Japonskem, </event>
      <event start="T3" end="T7-327">no. </event>
      <event start="T24-117" end="T26-515">K@k si do Zagreba pršva? </event>
      <event start="T43-813" end="T12">Čak </event>
      <event start="T12" end="T46-691">do Pragerskega pa ka? </event>
      <event start="T46-691" end="T48-133">Vlak al bus? </event>
      <event start="T50-642" end="T51-553">Aaa. </event>
      <event start="T69-347" end="T71-301">Klasika. </event>
      <event start="T71-301" end="T73-284">A s pozabva kaj? </event>
      <event start="T91-191" end="T28">Al s() al si si naredva preventivno plac zato, da lahk tam eee na() eee nakupiš </event>
      <event start="T28" end="T97-756">pa zravn prneseš? </event>
      <event start="T132-941" end="T35">Doro, doro. </event>
      <event start="T35" end="T36">Dojst o tem, </event>
      <event start="T36" end="T135-863">okej. </event>
      <event start="T135-863" end="T37">Kje sma ostava, </event>
      <event start="T37" end="T38">pršva si do Zagreba, </event>
      <event start="T38" end="T139-613">tam si šva na letalo? </event>
      <event start="T144-457" end="T146-302">Okej. </event>
      <event start="T147-191" end="T39">Ja, </event>
      <event start="T39" end="T148-719">okej. </event>
      <event start="T183-250" end="T186-051">Tak last minit predstavitve so itak najbolš. </event>
      <event start="T186-936" end="T50">Sam čak, </event>
      <event start="T50" end="T190-341">to je bvo kao v sklopu faksa al? </event>
      <event start="T241-52" end="T59">K@k, ka je bil pa kriterij, va() </event>
      <event start="T59" end="T247-043">sej ni vas sam osem na smeri? </event>
      <event start="T280-88" end="T282-305">Ja, </event>
      <event start="T282-305" end="T282-746">poslušam še. </event>
      <event start="T282-746" end="T283-445">Fer enaf. </event>
      <event start="T284-91" end="T286-12">Mislim ... </event>
      <event start="T286-12" end="T67">Okej, </event>
      <event start="T67" end="T287-884">zej ze() </event>
      <event start="T287-884" end="T68">zej s po(), zej s povedva, k@k si sploh to zravn pršva, </event>
      <event start="T68" end="T291-736">zej, zej pa pač ... </event>
      <event start="T291-736" end="T69">eee </event>
      <event start="T69" end="T70">nadaljuj, kje, kje s(), </event>
      <event start="T70" end="T71">čak, </event>
      <event start="T71" end="T72">zej sma ... </event>
      <event start="T72" end="T298-857">zej si rekva, ka je blo na letalu. </event>
      <event start="T300-515" end="T302-159">Ja. </event>
      <event start="T339-825" end="T340-688">Pač zaka n() ... </event>
      <event start="T340-688" end="T81">zakaj v eno zem bi mogu b@t hujš </event>
      <event start="T81" end="T344-684">oziroma zakaj več traja? </event>
      <event start="T345-325" end="T347-068">Ka ste meli drugo turo al ka? </event>
      <event start="T364-803" end="T87">Okej, </event>
      <event start="T87" end="T366-501">fer enof. </event>
      <event start="T367-19" end="T88">Eee </event>
      <event start="T88" end="T370-256">prva stvar, ko s dov pristala? </event>
      <event start="T409-126" end="T415-201">Všeč mi je, da nisi rekva, da prva stvar, ko s naredva, si začela ploskat, ko ste prstali. </event>
      <event start="T417-462" end="T418-65">A veš, ka mislim? </event>
      <event start="T418-65" end="T419-454">[nerazumljivo] </event>
      <event start="T433-295" end="T435-15">[smeh] </event>
      <event start="T435-15" end="T437-429">Fer enof. </event>
      <event start="T467-189" end="T104">A, </event>
      <event start="T104" end="T467-826">okej. </event>
      <event start="T476-56" end="T107">Ja, </event>
      <event start="T107" end="T108">sam čak, </event>
      <event start="T108" end="T479-244">v japonščini to al? </event>
      <event start="T480-481" end="T110">A, </event>
      <event start="T110" end="T481-257">okej okej. </event>
      <event start="T499-145" end="T113">Škoda, </event>
      <event start="T113" end="T501-429">mi tega nimamo. </event>
      <event start="T508-261" end="T117">Mislim, </event>
      <event start="T117" end="T449">če že daš neki inputa n@tr pač, </event>
      <event start="T449" end="T516-089">da maš vsej filing, da se ti je splačal sploh karkol narest. </event>
      <event start="T518-708" end="T120">Ka ste še pa pol šl@ izven </event>
      <event start="T120" end="T121">eee, bi reku, </event>
      <event start="T121" end="T525-887">okvirjev od faksa pogl@at? </event>
      <event start="T593-182" end="T132">Čak, </event>
      <event start="T132" end="T595-64">za k@jk dni sploh šva? </event>
      <event start="T633-11" end="T635-217">[nerazumljivo] </event>
      <event start="T644-754" end="T138">Kenslali, </event>
      <event start="T138" end="T646-913">luba duša. </event>
      <event start="T650-348" end="T140">S kod s pa, </event>
      <event start="T140" end="T652-533">pizdarija. </event>
      <event start="T660-603" end="T144">Skenclali, </event>
      <event start="T144" end="T663-872">ne pa skenslati, </event>
      <event start="T663-872" end="T145">mislim, </event>
      <event start="T145" end="T665-974">skenclaš. </event>
      <event start="T665-974" end="T667-421">Dej no. </event>
      <event start="T675-419" end="T678-138">A, a, a bejž. </event>
      <event start="T678-635" end="T680-155">N() ne bi si mislu. </event>
      <event start="T681-890" end="T683-763">Od kdaj naprej pa? </event>
      <event start="T685-831" end="T686-502">Mislim, </event>
      <event start="T686-502" end="T687-356">Džizs. </event>
      <event start="T728-463" end="T162">Ja čak, </event>
      <event start="T162" end="T457">ka pa pol, ko s nazaj pršva, </event>
      <event start="T457" end="T733-961">ste mogli eee za faks kako poročilo narest? </event>
      <event start="T733-961" end="T735-72">Predstavit ... </event>
      <event start="T736-734" end="T737-801">Al je blo to to? </event>
      <event start="T769-315" end="T168">O fak, </event>
      <event start="T168" end="T169">ja, </event>
      <event start="T169" end="T772-68">kje sploh začet? </event>
      <event start="T772-68" end="T773-888">[glas] </event>
      <event start="T773-888" end="T775-605">[premor] </event>
      <event start="T775-605" end="T776-85">Eee ... </event>
      <event start="T776-85" end="T778-180">[glas] </event>
      <event start="T778-180" end="T782-635">Mmm mislim eem ... </event>
      <event start="T782-635" end="T786-495">De() decembra še nisn vedu glih, ka bo z novim letom. </event>
      <event start="T786-495" end="T170">Eee takrat, ko bi mogu dobit šiht, </event>
      <event start="T170" end="T793-849">so pol e() enga drugega vzeli za senior pozicijo. </event>
      <event start="T793-849" end="T797-802">Eem ... [glas] </event>
      <event start="T797-802" end="T171">Po pa, po pa itak pač, </event>
      <event start="T171" end="T172">ko ne veš, ka bo čez par mescov, s pač tak ono, </event>
      <event start="T172" end="T804-422">pač bo, ka b() ... </event>
      <event start="T804-422" end="T173">Po pa itak prvi dan po novem letu prid() pridem v pisarno, </event>
      <event start="T173" end="T810-423">pride ta novi, </event>
      <event start="T810-423" end="T174">pa ga šef predstavi </event>
      <event start="T174" end="T813-48">pa reče: </event>
      <event start="T813-48" end="T175">"No, </event>
      <event start="T175" end="T176">t@t, t@t, tole je vaš študent, </event>
      <event start="T176" end="T818-149">zaenkrat še. </event>
      <event start="T818-149" end="T821-918">Delamo na tem, da bo čim prej redno zaposlen." </event>
      <event start="T821-918" end="T823-668">[premor] </event>
      <event start="T823-668" end="T178">Eem </event>
      <event start="T178" end="T177">po pa ja, </event>
      <event start="T177" end="T459">po pa kr naenkrat pa pač dobiš papirje od kadro(), </event>
      <event start="T459" end="T460">mislim, kadrovski vprašalnik, </event>
      <event start="T460" end="T831-369">da izpolneš pač s kod s@, </event>
