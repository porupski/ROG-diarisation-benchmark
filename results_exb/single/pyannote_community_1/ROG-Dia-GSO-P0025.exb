      <event start="T1664-238" end="T1667-132">[premor] </event>
      <event start="T1667-132" end="T373">Ej, </event>
      <event start="T373" end="T1670-354">t@k najedu sn se ga. </event>
      <event start="T1670-354" end="T1671-99">Ti si ja nor. </event>
