      <event start="T1962-470" end="T1964-063">[premor] </event>
      <event start="T1964-063" end="T1965-216">Eh. </event>
      <event start="T1965-216" end="T1966-837">Pač vodo pripraviš </event>
      <event start="T1966-837" end="T425">pa metlo vzameš, </event>
