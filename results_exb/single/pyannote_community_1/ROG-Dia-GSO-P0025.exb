      <event start="T480-481" end="T110">A, </event>
      <event start="T110" end="T481-257">okej okej. </event>
      <event start="T499-145" end="T113">Škoda, </event>
      <event start="T113" end="T501-429">mi tega nimamo. </event>
      <event start="T508-261" end="T117">Mislim, </event>
      <event start="T117" end="T449">če že daš nekaj inputa noter pač, </event>
      <event start="T449" end="T516-089">da imaš vsaj filing, da se ti je splačalo sploh karkoli narediti. </event>
      <event start="T518-708" end="T120">Kaj ste še pa pol šli izven </event>
      <event start="T120" end="T121">eee, bi rekel, </event>
      <event start="T121" end="T525-887">okvirjev od faksa pogledat? </event>
      <event start="T593-182" end="T132">Čakaj, </event>
      <event start="T132" end="T595-64">za koliko dni sploh šla? </event>
      <event start="T633-11" end="T635-217">[nerazumljivo] </event>
      <event start="T644-754" end="T138">Kenslali, </event>
      <event start="T138" end="T646-913">ljuba duša. </event>
      <event start="T650-348" end="T140">S kod si pa, </event>
      <event start="T140" end="T652-533">pizdarija. </event>
      <event start="T660-603" end="T144">Skenclali, </event>
      <event start="T144" end="T663-872">ne pa skenslati, </event>
