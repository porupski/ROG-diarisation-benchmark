    <tier id="COLLOQ_ROG-dialog-0022" speaker="ROG-dialog-0022" category="colloq" type="a" display-name="ROG-dialog-0022 [colloq]">
      <event start="T10-106" end="T11-27">Veš, da sem, </event>
      <event start="T11-27" end="T365">veš, da sem, </event>
      <event start="T365" end="T14-842">sej s tem namenom sen tudi prišla [smeh]. </event>
      <event start="T16-142" end="T18-659">Ker sen vedla, da bo gibanca danes. </event>
      <event start="T20-176" end="T20-896">Ja. </event>
      <event start="T20-896" end="T23-031">In kak si ti? </event>
      <event start="T28-499" end="T8">Ja, </event>
      <event start="T8" end="T9">neke si rekla, </event>
      <event start="T9" end="T30-611">ja. </event>
      <event start="T30-611" end="T31-993">Kak je blo? </event>
      <event start="T58-341" end="T60-154">Res. </event>
      <event start="T60-154" end="T19">Res, </event>
      <event start="T19" end="T20">sej jez sem tut bla, </event>
      <event start="T20" end="T21">eee, </event>
      <event start="T21" end="T67-755">j@z sem bla d() marca lani. </event>
      <event start="T68-383" end="T22">Eee tudi, </event>
      <event start="T22" end="T23">pa sem mela eno tako v redi eee zdravnico, </event>
      <event start="T23" end="T73-23">res. </event>
      <event start="T73-23" end="T75-932">Pol je tak šla v porodniško. </event>
      <event start="T75-932" end="T78-322">Tak da, </event>
      <event start="T78-322" end="T24">da je blo, </event>
      <event start="T24" end="T25">svetovno je blo drugače, </event>
      <event start="T25" end="T26">mislim, </event>
      <event start="T26" end="T27">naredla vse okej, </event>
      <event start="T27" end="T28">tipi top, </event>
      <event start="T28" end="T84-483">ne. </event>
      <event start="T84-483" end="T86-515">Enekcija pa katastrofa. </event>
      <event start="T88-564" end="T89-408">Ful. </event>
      <event start="T90-022" end="T29">Ja, </event>
      <event start="T29" end="T91-548">od enekcije. </event>
      <event start="T92-995" end="T30">Eee </event>
      <event start="T30" end="T96-243">malo me je. </event>
      <event start="T96-243" end="T101-091">Najhujše je blo takrat, ko sem eee šla šive ven dajat. </event>
      <event start="T101-963" end="T31">Eee </event>
      <event start="T31" end="T108-897">ker ob strani se je šiv dejansko zažr not </event>
      <event start="T108-897" end="T111-005">in ni šov ven. </event>
      <event start="T111-005" end="T32">Eee </event>
      <event start="T32" end="T33">tak da pari šivof je mi ostalo not, ki so pol sami šli vun, </event>
      <event start="T33" end="T116-25">ne. </event>
      <event start="T117-213" end="T34">Ja, </event>
      <event start="T34" end="T119-412">kak je pa pr tebi blo? </event>
      <event start="T137-885" end="T42">Mhm, </event>
      <event start="T42" end="T139-933">to sem jaz tut mela. </event>
      <event start="T144-918" end="T146-306">Še zdaj? </event>
      <event start="T150-301" end="T152-512">Se nimaš plavo pa nič. </event>
      <event start="T155-292" end="T156-3">Ne vem. </event>
      <event start="T156-3" end="T51">Kaj si probala si ti tak po veki potegnit, </event>
      <event start="T51" end="T52">eee </event>
      <event start="T52" end="T162-42">maš kake bulice not? </event>
      <event start="T164-551" end="T165-129">Ja. </event>
      <event start="T165-129" end="T166-625">To so šivi not. </event>
      <event start="T167-647" end="T169-989">Ti bojo sami izpadli ven. </event>
      <event start="T173-010" end="T53">Šivi, </event>
