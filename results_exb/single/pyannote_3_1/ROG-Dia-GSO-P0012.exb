      <event start="T1142-743" end="T1144-162">[smeh] </event>
      <event start="T1144-162" end="T1144-59">Kaj? </event>
      <event start="T1146-789" end="T1147-384">A ne? </event>
      <event start="T1149-595" end="T330">Pa daj mir. </event>
