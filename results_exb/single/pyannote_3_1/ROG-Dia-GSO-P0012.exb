    <tier id="COLLOQ_ROG-dialog-0021" speaker="ROG-dialog-0021" category="colloq" type="a" display-name="ROG-dialog-0021 [colloq]">
      <event start="T1-44" end="T1">Zdravo, </event>
      <event start="T1" end="T2-877">Zdenka, </event>
      <event start="T2-877" end="T2">kak sn vesela, da si danes prišla, </event>
      <event start="T2" end="T7-239">ravno danes pečem gibanco, </event>
      <event start="T7-239" end="T9-215">to, kar maš ti res najrajši. </event>
      <event start="T9-215" end="T10-106">Si vesela? </event>
      <event start="T14-842" end="T16-142">Ajaaa. </event>
      <event start="T18-659" end="T6">Ja, </event>
      <event start="T6" end="T20-176">super. </event>
      <event start="T23-031" end="T7">Ja, </event>
      <event start="T7" end="T3">čuj eee, </event>
      <event start="T3" end="T4">zaj sn v redu, </event>
      <event start="T4" end="T366">saj veš, </event>
      <event start="T366" end="T5">ne, </event>
      <event start="T5" end="T28-499">da sem bla na operaciji. </event>
      <event start="T30-611" end="T31-993">Ja. </event>
      <event start="T31-993" end="T10">Ja, </event>
      <event start="T10" end="T11">veš kaj, </event>
      <event start="T11" end="T35-854">prvo sem mela februarja, </event>
      <event start="T35-854" end="T38-255">šestndvajstiga februarja sem mela. </event>
      <event start="T38-255" end="T12">Tam nas je več not prišlo, </event>
      <event start="T12" end="T41-865">smo čakali. </event>
      <event start="T41-865" end="T13">Eem </event>
      <event start="T13" end="T44-658">veš, da tri ure smo čakali. </event>
      <event start="T44-658" end="T15">Čuj, </event>
      <event start="T15" end="T16">jaz sem bla ful zadovolna. </event>
      <event start="T16" end="T49-347">Moja dohtarca je bla tak v redi. </event>
      <event start="T49-347" end="T51-509">Vse me je super porihtala. </event>
      <event start="T51-509" end="T17">Tiste enekcije malo zapečejo, </event>
      <event start="T17" end="T18">ampak nekaj pa moremo potrpet, </event>
      <event start="T18" end="T58-341">ne. </event>
      <event start="T58-341" end="T60-154">Tak da. </event>
      <event start="T67-755" end="T68-383">Ja. </event>
      <event start="T86-515" end="T88-564">Pl() si bla kej plava? </event>
      <event start="T89-408" end="T90-022">Ful? </event>
      <event start="T91-548" end="T92-995">Pa je tisto bolelo? </event>
      <event start="T101-091" end="T101-963">Aha. </event>
      <event start="T116-25" end="T117-213">Mhm mhm. </event>
      <event start="T119-412" end="T35">Ja, </event>
      <event start="T35" end="T36">pri meni, </event>
      <event start="T36" end="T123-149">jaz sem mela tudi ogromno šivov. </event>
      <event start="T123-149" end="T37">Ampak je, </event>
      <event start="T37" end="T38">je spravla ven, </event>
      <event start="T38" end="T39">ampak ostale pa so še te ranice, </event>
      <event start="T39" end="T129-549">ne. </event>
      <event start="T129-549" end="T40">Eee, </event>
      <event start="T40" end="T41">pa zaj si mažem, </event>
      <event start="T41" end="T137-885">še vedno si mažem z eno antibiotično kremo. </event>
      <event start="T137-885" end="T139-933">Eem. </event>
      <event start="T139-933" end="T367">Tudi, </event>
      <event start="T367" end="T43">ne? </event>
      <event start="T43" end="T44">Eee </event>
      <event start="T44" end="T45">pa obhladke si morem gor dajat, </event>
      <event start="T45" end="T144-918">ne. </event>
      <event start="T146-306" end="T46">Ja, ne vem, </event>
      <event start="T46" end="T47">jaz si še to ... </event>
      <event start="T47" end="T48">Edino fčerej pa res nisem, </event>
      <event start="T48" end="T150-301">sem pozabla. </event>
      <event start="T150-301" end="T151-637">Eee. </event>
      <event start="T152-512" end="T50">Ja, </event>
      <event start="T50" end="T49">ne vem, </event>
      <event start="T49" end="T155-292">zaka pa si mormo dajat gor? </event>
      <event start="T162-42" end="T368">Ja, </event>
      <event start="T368" end="T165-129">tu tak čist malo se mi zdi, da mam. </event>
      <event start="T166-625" end="T167-647">Aja? </event>
      <event start="T171-459" end="T174-168">Šivi da bi še bli tu noter? </event>
      <event start="T175-716" end="T178-109">Pa kaj si ti smešna. </event>
      <event start="T178-109" end="T54">No, </event>
      <event start="T54" end="T55">drugače ... </event>
      <event start="T55" end="T182-31">A? </event>
      <event start="T189-302" end="T190-007">Ja. </event>
      <event start="T190-562" end="T59">Pa veš, da so še tam, </event>
      <event start="T59" end="T60">eee ne morem verjet, </event>
      <event start="T60" end="T61">ne, </event>
      <event start="T61" end="T194-85">tam so še moški bli. </event>
      <event start="T194-85" end="T62">Jz sem rekla: </event>
      <event start="T62" end="T63">"Kak je te to možno? </event>
      <event start="T63" end="T199-066">Te moški tudi grejo?" </event>
      <event start="T199-066" end="T64">Ja, </event>
      <event start="T64" end="T65">te že, </event>
      <event start="T65" end="T200-034">ne. </event>
      <event start="T200-581" end="T201-366">Pri vas tut? </event>
      <event start="T202-725" end="T203-637">Aha. </event>
      <event start="T204-818" end="T67">Eee </event>
      <event start="T67" end="T206-712">veš, ka ti še morem povedat? </event>
      <event start="T207-267" end="T66">Da je pa moja kolegica bla, </event>
      <event start="T66" end="T210-121">ne. </event>
      <event start="T210-925" end="T215-384">In ona bi bla isto naročena ko jaz. </event>
      <event start="T215-384" end="T69">Pa ker je pač, nekej ni bla zdrava, </event>
      <event start="T69" end="T220-278">pa je en tedn šla kasneje. </event>
      <event start="T220-278" end="T223-977">In ona meni pošle sliko. </event>
      <event start="T223-977" end="T225-926">Ona je bla tako rdeča. </event>
      <event start="T225-926" end="T228-229">Ko da bi mela še neke rane gor. </event>
      <event start="T228-229" end="T70">Ne vem, </event>
      <event start="T70" end="T71">ne vem, ka je to blo, </event>
      <event start="T71" end="T230-88">jaz niam pojma. </event>
      <event start="T230-88" end="T72">Al pa je [glas] </event>
      <event start="T72" end="T73">al pa se ni držala tega, da bi si delala obkladke </event>
