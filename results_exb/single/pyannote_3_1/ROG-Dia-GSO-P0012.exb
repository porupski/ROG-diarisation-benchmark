      <event start="T166-625" end="T167-647">Aja? </event>
      <event start="T171-459" end="T174-168">Šivi da bi še bili tu noter? </event>
      <event start="T175-716" end="T178-109">Pa kaj si ti smešna. </event>
      <event start="T178-109" end="T54">No, </event>
      <event start="T54" end="T55">drugače ... </event>
      <event start="T55" end="T182-31">A? </event>
      <event start="T189-302" end="T190-007">Ja. </event>
      <event start="T190-562" end="T59">Pa veš, da so še tam, </event>
