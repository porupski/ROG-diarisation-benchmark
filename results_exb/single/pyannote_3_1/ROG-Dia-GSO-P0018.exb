      <event start="T323-534" end="T325-118">Na ja. </event>
      <event start="T328-549" end="T329-03">Ja. </event>
      <event start="T341-421" end="T341-938">Ja. </event>
      <event start="T342-586" end="T342-876">Ja. </event>
      <event start="T344-837" end="T107">Ja, </event>
      <event start="T107" end="T346-788">oki [nerazumljivo]. </event>
      <event start="T359-344" end="T359-974">Ja. </event>
      <event start="T360-567" end="T361-072">Ja. </event>
      <event start="T373-607" end="T375-732">[smeh] </event>
      <event start="T377-471" end="T378-021">Ja. </event>
      <event start="T381-499" end="T383-136">[smeh] </event>
      <event start="T383-136" end="T383-729">Vsi so šli. </event>
      <event start="T383-729" end="T123">Ne, </event>
      <event start="T123" end="T387-004">men je pa enkrat ... pr mami Miri ... v Tržiču, </event>
      <event start="T387-004" end="T388-258">[smeh] </event>
      <event start="T388-258" end="T389-955">tko veš, uni Lumpi bomboni, k so bli. </event>
      <event start="T389-955" end="T392-542">Najb@l trdi. </event>
      <event start="T392-542" end="T392-853">Ja. </event>
      <event start="T393-422" end="T394-553">Najb@l trdi. </event>
      <event start="T394-553" end="T396-656">Jz tko enkrat žvečm ta bombon, </event>
