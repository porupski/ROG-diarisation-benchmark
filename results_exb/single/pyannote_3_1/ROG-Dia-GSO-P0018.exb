      <event start="T316-116" end="T98">Še kr me boli zob. </event>
      <event start="T98" end="T317-435">[smeh] </event>
      <event start="T317-435" end="T99">[smeh] </event>
      <event start="T99" end="T319-119">Zdej je še slabš. </event>
      <event start="T319-119" end="T321-199">Ker zdej me tud na dotik boli. </event>
