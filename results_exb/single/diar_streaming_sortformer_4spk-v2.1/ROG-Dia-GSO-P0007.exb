    <tier id="COLLOQ_ROG-dialog-0011" speaker="ROG-dialog-0011" category="colloq" type="a" display-name="ROG-dialog-0011 [colloq]">
      <event start="T1-288" end="T2-199">Hej. </event>
      <event start="T3-785" end="T5-085">K@k si? </event>
      <event start="T8-03" end="T2">Js tut. </event>
      <event start="T2" end="T544">Veš, </event>
      <event start="T544" end="T10-638">ka ti morm povedat. </event>
      <event start="T11-403" end="T3">Aaa. </event>
      <event start="T3" end="T545">Veš, </event>
      <event start="T545" end="T14-546">ka sm dans delala? </event>
      <event start="T16-797" end="T18-691">Kuhno sem žagala. </event>
      <event start="T20-435" end="T5">Ja, </event>
      <event start="T5" end="T23-229">z vbodno žago. </event>
      <event start="T26-015" end="T26-423">Ja. </event>
      <event start="T27-739" end="T8">Carica, </event>
      <event start="T8" end="T28-465">ne? </event>
      <event start="T32-994" end="T34-784">Pol kuhne sm zdej stran dala, </event>
      <event start="T34-784" end="T36-412">odrezala, </event>
      <event start="T36-412" end="T39-779">z eee vbodno žago. </event>
      <event start="T39-779" end="T41-837">Prestavla v dnevno, </event>
      <event start="T41-837" end="T43-815">zdej pa ne znam indukcije skupi sestavt. </event>
      <event start="T45-618" end="T13">Eee mož mi je pomagal. </event>
      <event start="T13" end="T49-078">Ja, ja, ja, ja. </event>
      <event start="T52-236" end="T53-893">Pa ploščice dol, </event>
      <event start="T53-893" end="T55-161">morem dol dat. </event>
      <event start="T55-161" end="T15">Pa bo hmal, </event>
      <event start="T15" end="T16">čez štir tedne bo že nova kuhna, </event>
      <event start="T16" end="T58-153">veš? </event>
      <event start="T62-314" end="T64-027">Saj zato sem pršla k teb. </event>
      <event start="T65-307" end="T19">Ja, </event>
      <event start="T19" end="T68-081">zato sem pršla k teb, da mi posodiš jo. </event>
      <event start="T71-073" end="T23">Ja, </event>
      <event start="T23" end="T72-413">hvala ti. </event>
      <event start="T74-719" end="T76-315">Uporabiš, ne? </event>
      <event start="T76-315" end="T77-129">[smeh] </event>
      <event start="T77-129" end="T78-17">Ampak včeri, </event>
      <event start="T78-17" end="T80-763">včeri sem pa pečico dol nesla. </event>
      <event start="T81-488" end="T24">Iz četrtega štuka dol. </event>
      <event start="T24" end="T85-253">Ne morš verjet </event>
      <event start="T86-977" end="T87-995">Z možom. </event>
      <event start="T88-505" end="T90-095">Ja, ja, ja. </event>
      <event start="T92-399" end="T94-142">Štiri, štiri. </event>
      <event start="T97-908" end="T98-779">Pa ga ni. </event>
      <event start="T98-779" end="T99-375">Pa dobr, </event>
      <event start="T99-375" end="T29">sn hotla otroka porabit, </event>
      <event start="T29" end="T30">ampak potem nisem. </event>
      <event start="T30" end="T102-723">Sn rekla, </event>
      <event start="T102-723" end="T103-872">bom raj počakala. </event>
      <event start="T103-872" end="T104-224">Ja. </event>
      <event start="T105-172" end="T106-911">Dons pa že kr na odpad. </event>
      <event start="T107-517" end="T108-013">Ja. </event>
      <event start="T110-403" end="T114-477">V kuhni je še ena eee zgorna, </event>
      <event start="T114-477" end="T116-078">eee psiha. </event>
      <event start="T116-078" end="T116-922">Omarica. </event>
      <event start="T116-922" end="T117-882">Element ta zgorn, </event>
      <event start="T118-527" end="T32">eee </event>
      <event start="T32" end="T120-628">pa pol spodne. </event>
      <event start="T120-628" end="T122-602">Umivalnik pa pomivalc pa miza. </event>
      <event start="T124-932" end="T125-832">Krožnike ... </event>
      <event start="T125-832" end="T129-339">Tisto bom stran dala v ... v dnevno. </event>
      <event start="T129-339" end="T33">V dnevno bom dala </event>
      <event start="T33" end="T133-254">pa bom ku() v dnevni kuhala. </event>
      <event start="T134-951" end="T550">Ja, </event>
      <event start="T550" end="T136-610">za štir tedne. </event>
      <event start="T139-346" end="T141-624">Prenosna kuhna. </event>
      <event start="T145-389" end="T149-127">Kuhna bo dvandvajstega jo prpelejo četrtega. </event>
      <event start="T149-733" end="T150-533">Aprila. </event>
      <event start="T151-132" end="T153-456">Trindvajstga jo sestavlajo. </event>
      <event start="T154-714" end="T157-092">Pet@ndvajstga mam pa dopust, da kuham. </event>
      <event start="T159-402" end="T160-86">Bom, bom. </event>
      <event start="T160-86" end="T161-367">Bom. </event>
      <event start="T162-834" end="T40">Ja, ne vem, </event>
      <event start="T40" end="T164-748">vrjetno kako mongolsko, </event>
      <event start="T164-748" end="T166-175">k jo mate vsi radi. </event>
      <event start="T166-175" end="T166-638">[smeh] </event>
      <event start="T168-077" end="T168-446">Ja. </event>
      <event start="T169-587" end="T171-228">[smeh] </event>
      <event start="T172-454" end="T174-948">Mongolsko pa en dober vinček zraven, </event>
      <event start="T174-948" end="T175-295">ne? </event>
      <event start="T178-444" end="T179-177">Ja, </event>
      <event start="T179-177" end="T180-090">čis enostavn. </event>
      <event start="T181-579" end="T183-349">Eee. </event>
      <event start="T183-349" end="T43">Ja, more bit, </event>
      <event start="T43" end="T185-97">najprej more bit fajni meso. </event>
      <event start="T186-862" end="T189-021">Pol ga pa tak na mejhne koščke narežeš, </event>
      <event start="T189-021" end="T190-21">lepo stolčeš. </event>
      <event start="T191-391" end="T192-631">Ful stolčeš. </event>
      <event start="T192-631" end="T45">Eee </event>
      <event start="T45" end="T199-25">pol pa daš sojino, ostrigino omako pa pa eee olje pa vino belo. </event>
      <event start="T199-896" end="T200-958">Belo. </event>
      <event start="T200-958" end="T46">Par žlic, </event>
      <event start="T46" end="T202-717">nič več. </event>
      <event start="T203-105" end="T205-871">Potem pa daš to v hladilnik. </event>
      <event start="T205-871" end="T207-298">Za štir ure. </event>
      <event start="T207-298" end="T208-083">Počiv(), </event>
      <event start="T208-083" end="T208-749">v pac. </event>
      <event start="T209-593" end="T210-259">Tako. </event>
      <event start="T211-935" end="T49">Pol pa vsako </event>
      <event start="T49" end="T48">pol pa p() spečeš t@t meso, </event>
      <event start="T48" end="T216-834">med tem cajtom pa narežeš por. </event>
      <event start="T217-539" end="T50">Pa </event>
      <event start="T50" end="T51">eee </event>
      <event start="T51" end="T220-523">česen olupiš. </event>
      <event start="T221-534" end="T52">Tist meso, </event>
      <event start="T52" end="T53">ko ga pa pečeš, </event>
      <event start="T53" end="T225-271">morš pa po žlico pečit. </event>
      <event start="T225-271" end="T54">Ker se mon() eee </event>
      <event start="T54" end="T229-06">stisne se skupi, veš eee ... </event>
      <event start="T229-06" end="T232-851">Tak pacast pride od eee sojine pa ostrigine omake. </event>
      <event start="T235-952" end="T55">Ja, </event>
      <event start="T55" end="T237-232">ful olja. </event>
      <event start="T240-183" end="T240-789">Mhm. </event>
      <event start="T240-789" end="T56">Po malem, </event>
      <event start="T56" end="T57">po žlico moreš </event>
      <event start="T57" end="T243-663">in to pol traja. </event>
      <event start="T244-666" end="T247-327">Pa šprica, tko da morš met obvezno pokrovko. </event>
      <event start="T247-327" end="T248-479">Pa ukrog. </event>
      <event start="T248-479" end="T249-589">Za ... </event>
      <event start="T250-837" end="T251-405">Pol pa por, </event>
      <event start="T251-405" end="T253-71">ampak sam zelen del od pora. </event>
      <event start="T254-661" end="T256-845">Nč unga steb@l, ko je bel. </event>
      <event start="T256-845" end="T259-025">Sam zeleni del na take trakce narežeš, </event>
