    <tier id="COLLOQ_ROG-dialog-0007" speaker="ROG-dialog-0007" category="colloq" type="a" display-name="ROG-dialog-0007 [colloq]">
      <event start="T0-555" end="T2">Kaj zdej, </event>
      <event start="T2" end="T3-017">si kupla karte za na Sardinijo? </event>
      <event start="T5-403" end="T6">Ja, pa sej je čist enostavno. </event>
      <event start="T6" end="T7">Tm greš na uno spletno str@n od Rajenera, </event>
      <event start="T7" end="T8">puhledaš datume, </event>
      <event start="T8" end="T22">puhledaš cene </event>
      <event start="T22" end="T12-533">in puol si zbjereš. </event>
      <event start="T12-533" end="T9">Kulk cajta ... </event>
      <event start="T9" end="T16-579">kulk cajta bi bla tm? </event>
      <event start="T16-579" end="T10">Vječ cajta ku si, </event>
      <event start="T10" end="T18-133">bl poceni je. </event>
      <event start="T20-669" end="T13">Ja, </event>
      <event start="T13" end="T14">ti bi rada sam, </event>
      <event start="T14" end="T21">da ti drugi zrihtaju </event>
      <event start="T21" end="T23-316">pa da ti hrješ. </event>
      <event start="T26-411" end="T18">No, </event>
      <event start="T18" end="T19">ma tm si naluoži tisto aplikacijo od Rajener </event>
      <event start="T19" end="T20">in se prjav@š </event>
      <event start="T20" end="T32-282">in puol zbjereš karto. [zvok] </event>
      <event start="T34-931" end="T35-679">Ne, </event>
      <event start="T35-679" end="T36-904">morš met aplikacijo. </event>
      <event start="T37-794" end="T26">Ja, </event>
      <event start="T26" end="T40-45">ker pol maš shranjene te karte v aplikaciji. </event>
      <event start="T42-701" end="T296">Ja, </event>
      <event start="T296" end="T29">puol si jih pa še natisn@š, </event>
      <event start="T29" end="T30">č() če ti slučajn telefon crkne. </event>
      <event start="T30" end="T46-755">Ja. </event>
      <event start="T48-336" end="T33">Tm zbjereš, </event>
      <event start="T33" end="T34">pol se prjav@š, </event>
      <event start="T34" end="T35">prjav@š tiste usjebe, </event>
      <event start="T35" end="T53-776">ku grjejo. </event>
      <event start="T53-776" end="T36">Pa mor bit prov napisano. </event>
      <event start="T36" end="T56-595">Morjo bit vse črke prov. </event>
      <event start="T58-838" end="T37">Lohku eee z doplačil@m, </event>
      <event start="T37" end="T38">misl@m, da je desjet evru, </event>
      <event start="T38" end="T66-083">da zamenjaš eee naslov eee naslovnika karte. </event>
      <event start="T66-93" end="T39">Ja, </event>
      <event start="T39" end="T68-851">in pol s kartico plačaš. </event>
      <event start="T69-978" end="T72-147">Kartico j@maš za plačat? </event>
      <event start="T72-636" end="T73-12">Bančno? </event>
      <event start="T73-508" end="T73-944">A j@maš? </event>
      <event start="T75-105" end="T41">A no, </event>
      <event start="T41" end="T75-957">tistu j@maš. </event>
      <event start="T75-957" end="T78-046">No, in pol ko plačaš ... </event>
      <event start="T78-046" end="T242">puol pa hr@š nazaj v aplikacijo </event>
      <event start="T242" end="T81-743">in nardiš tisti ček in. </event>
      <event start="T82-496" end="T44">Ne? </event>
      <event start="T44" end="T45">In tm ti piše puol, </event>
      <event start="T45" end="T121">ob kulki uri grješ </event>
      <event start="T121" end="T46">in kdaj pristaneš. </event>
