    <tier id="COLLOQ_ROG-dialog-0021" speaker="ROG-dialog-0021" category="colloq" type="a" display-name="ROG-dialog-0021 [colloq]">
      <event start="T1-44" end="T1">Zdravo, </event>
      <event start="T1" end="T2-877">Zdenka, </event>
      <event start="T2-877" end="T2">kak sn vesela, da si danes prišla, </event>
      <event start="T2" end="T7-239">ravno danes pečem gibanco, </event>
      <event start="T7-239" end="T9-215">to, kar maš ti res najrajši. </event>
      <event start="T9-215" end="T10-106">Si vesela? </event>
      <event start="T14-842" end="T16-142">Ajaaa. </event>
      <event start="T18-659" end="T6">Ja, </event>
      <event start="T6" end="T20-176">super. </event>
      <event start="T23-031" end="T7">Ja, </event>
      <event start="T7" end="T3">čuj eee, </event>
      <event start="T3" end="T4">zaj sn v redu, </event>
      <event start="T4" end="T366">saj veš, </event>
      <event start="T366" end="T5">ne, </event>
      <event start="T5" end="T28-499">da sem bla na operaciji. </event>
      <event start="T30-611" end="T31-993">Ja. </event>
      <event start="T31-993" end="T10">Ja, </event>
      <event start="T10" end="T11">veš kaj, </event>
      <event start="T11" end="T35-854">prvo sem mela februarja, </event>
      <event start="T35-854" end="T38-255">šestndvajstiga februarja sem mela. </event>
      <event start="T38-255" end="T12">Tam nas je več not prišlo, </event>
      <event start="T12" end="T41-865">smo čakali. </event>
      <event start="T41-865" end="T13">Eem </event>
      <event start="T13" end="T44-658">veš, da tri ure smo čakali. </event>
      <event start="T44-658" end="T15">Čuj, </event>
      <event start="T15" end="T16">jaz sem bla ful zadovolna. </event>
      <event start="T16" end="T49-347">Moja dohtarca je bla tak v redi. </event>
      <event start="T49-347" end="T51-509">Vse me je super porihtala. </event>
      <event start="T51-509" end="T17">Tiste enekcije malo zapečejo, </event>
      <event start="T17" end="T18">ampak nekaj pa moremo potrpet, </event>
      <event start="T18" end="T58-341">ne. </event>
      <event start="T58-341" end="T60-154">Tak da. </event>
      <event start="T67-755" end="T68-383">Ja. </event>
      <event start="T86-515" end="T88-564">Pl() si bla kej plava? </event>
      <event start="T89-408" end="T90-022">Ful? </event>
      <event start="T91-548" end="T92-995">Pa je tisto bolelo? </event>
      <event start="T101-091" end="T101-963">Aha. </event>
      <event start="T116-25" end="T117-213">Mhm mhm. </event>
      <event start="T119-412" end="T35">Ja, </event>
      <event start="T35" end="T36">pri meni, </event>
      <event start="T36" end="T123-149">jaz sem mela tudi ogromno šivov. </event>
      <event start="T123-149" end="T37">Ampak je, </event>
      <event start="T37" end="T38">je spravla ven, </event>
      <event start="T38" end="T39">ampak ostale pa so še te ranice, </event>
      <event start="T39" end="T129-549">ne. </event>
      <event start="T129-549" end="T40">Eee, </event>
      <event start="T40" end="T41">pa zaj si mažem, </event>
      <event start="T41" end="T137-885">še vedno si mažem z eno antibiotično kremo. </event>
      <event start="T137-885" end="T139-933">Eem. </event>
      <event start="T139-933" end="T367">Tudi, </event>
      <event start="T367" end="T43">ne? </event>
      <event start="T43" end="T44">Eee </event>
      <event start="T44" end="T45">pa obhladke si morem gor dajat, </event>
      <event start="T45" end="T144-918">ne. </event>
      <event start="T146-306" end="T46">Ja, ne vem, </event>
      <event start="T46" end="T47">jaz si še to ... </event>
      <event start="T47" end="T48">Edino fčerej pa res nisem, </event>
      <event start="T48" end="T150-301">sem pozabla. </event>
      <event start="T150-301" end="T151-637">Eee. </event>
      <event start="T152-512" end="T50">Ja, </event>
      <event start="T50" end="T49">ne vem, </event>
      <event start="T49" end="T155-292">zaka pa si mormo dajat gor? </event>
      <event start="T162-42" end="T368">Ja, </event>
      <event start="T368" end="T165-129">tu tak čist malo se mi zdi, da mam. </event>
      <event start="T166-625" end="T167-647">Aja? </event>
      <event start="T171-459" end="T174-168">Šivi da bi še bli tu noter? </event>
      <event start="T175-716" end="T178-109">Pa kaj si ti smešna. </event>
      <event start="T178-109" end="T54">No, </event>
      <event start="T54" end="T55">drugače ... </event>
      <event start="T55" end="T182-31">A? </event>
      <event start="T189-302" end="T190-007">Ja. </event>
      <event start="T190-562" end="T59">Pa veš, da so še tam, </event>
      <event start="T59" end="T60">eee ne morem verjet, </event>
      <event start="T60" end="T61">ne, </event>
      <event start="T61" end="T194-85">tam so še moški bli. </event>
      <event start="T194-85" end="T62">Jz sem rekla: </event>
      <event start="T62" end="T63">"Kak je te to možno? </event>
      <event start="T63" end="T199-066">Te moški tudi grejo?" </event>
      <event start="T199-066" end="T64">Ja, </event>
      <event start="T64" end="T65">te že, </event>
      <event start="T65" end="T200-034">ne. </event>
      <event start="T200-581" end="T201-366">Pri vas tut? </event>
      <event start="T202-725" end="T203-637">Aha. </event>
      <event start="T204-818" end="T67">Eee </event>
      <event start="T67" end="T206-712">veš, ka ti še morem povedat? </event>
      <event start="T207-267" end="T66">Da je pa moja kolegica bla, </event>
      <event start="T66" end="T210-121">ne. </event>
      <event start="T210-925" end="T215-384">In ona bi bla isto naročena ko jaz. </event>
      <event start="T215-384" end="T69">Pa ker je pač, nekej ni bla zdrava, </event>
      <event start="T69" end="T220-278">pa je en tedn šla kasneje. </event>
      <event start="T220-278" end="T223-977">In ona meni pošle sliko. </event>
      <event start="T223-977" end="T225-926">Ona je bla tako rdeča. </event>
      <event start="T225-926" end="T228-229">Ko da bi mela še neke rane gor. </event>
      <event start="T228-229" end="T70">Ne vem, </event>
      <event start="T70" end="T71">ne vem, ka je to blo, </event>
      <event start="T71" end="T230-88">jaz niam pojma. </event>
      <event start="T230-88" end="T72">Al pa je [glas] </event>
      <event start="T72" end="T73">al pa se ni držala tega, da bi si delala obkladke </event>
      <event start="T73" end="T74">pa mazala verjetno, </event>
      <event start="T74" end="T236-872">ne. </event>
      <event start="T236-872" end="T237-918">Tak da ... </event>
      <event start="T254-605" end="T255-315">Mhm mhm. </event>
      <event start="T257-028" end="T259-013">A dve si mela? </event>
      <event start="T264-819" end="T85">Da je do tega prišlo, </event>
      <event start="T85" end="T267-446">ne? </event>
      <event start="T267-446" end="T86">Aha. </event>
      <event start="T86" end="T87">Eee, </event>
      <event start="T87" end="T370">ja pa </event>
      <event start="T370" end="T274-947">kaj pol ko si ti šla eee tote šive ven vzet, je blo vse v redu? </event>
      <event start="T276-183" end="T276-655">Vse. </event>
      <event start="T280-975" end="T91">Aha, </event>
      <event start="T91" end="T282-687">pa še maš kaj kontrole? </event>
      <event start="T284-649" end="T93">Aha. </event>
      <event start="T93" end="T286-67">Veš, kaj pa se je še meni zgodlo? </event>
      <event start="T287-001" end="T94">Eee </event>
      <event start="T94" end="T95">meni pa v oko notr mi raste ena trepalnica, </event>
      <event start="T95" end="T293-348">ne. </event>
      <event start="T294-259" end="T96">In sem jo jaz </event>
      <event start="T96" end="T296-601">eee </event>
      <event start="T296-601" end="T97">doktorco fprašala, če bi ona meni lahko to odstranla, </event>
      <event start="T97" end="T98">ne, </event>
      <event start="T98" end="T307-968">ampak je rekla, da pač če bi ona to ven spipala, bi lahko ponovno rastlo. </event>
      <event start="T307-968" end="T309-694">Zato pa morem, </event>
      <event start="T309-694" end="T99">če se bom pač odločla, </event>
      <event start="T99" end="T312-824">če de me motlo, </event>
      <event start="T312-824" end="T101">eee </event>
      <event start="T101" end="T100">pač se morem ponovno pr njej naročit </event>
      <event start="T100" end="T102">pa bi mi operirala. </event>
      <event start="T102" end="T104">Tak da ne morem verjet tega, </event>
      <event start="T104" end="T103">kak lahko to tak noter raste, </event>
      <event start="T103" end="T105">dlaka, </event>
      <event start="T105" end="T321-89">ne. </event>
      <event start="T323-507" end="T325-108">Ja ja ja ja. </event>
      <event start="T326-009" end="T106">V oko, </event>
      <event start="T106" end="T327-613">ja. </event>
      <event start="T330-447" end="T107">Glih ti pravim, </event>
      <event start="T107" end="T333-114">če bi si to sama odstranla, </event>
      <event start="T333-114" end="T335-956">eee se baje to ponovno pojavi. </event>
      <event start="T335-956" end="T108">Ponovno zraste ven, </event>
      <event start="T108" end="T337-85">ne. </event>
      <event start="T339-178" end="T109">Ja sej. </event>
      <event start="T109" end="T341-283">Ja. </event>
      <event start="T344-463" end="T111">Mhm. </event>
      <event start="T111" end="T112">Jaz se zaj tut nisn odločla na to, </event>
      <event start="T112" end="T348-122">ne. </event>
      <event start="T348-122" end="T113">Bom vidla, kak bo. </event>
      <event start="T113" end="T114">Pač pustimo času čas, </event>
      <event start="T114" end="T352-003">ne. </event>
      <event start="T352-003" end="T352-695">Tak da ... </event>
      <event start="T354-949" end="T355-777">Ja, ja. [smeh] </event>
      <event start="T355-777" end="T116">Kaj si te misla? </event>
      <event start="T116" end="T357-816">Veš, kolko, </event>
      <event start="T357-816" end="T359-233">veš, kolko to stane? </event>
      <event start="T360-155" end="T117">Ti veš, kolko to stane, ka sma zaj </event>
      <event start="T117" end="T362-779">eee </event>
      <event start="T362-779" end="T118">kaj sem zaj jaz to mela, </event>
      <event start="T118" end="T364-992">ne? </event>
      <event start="T368-472" end="T119">To je pa res drago, </event>
      <event start="T119" end="T369-850">ne. </event>
      <event start="T369-850" end="T370-733">Ki boš te ... </event>
      <event start="T370-733" end="T120">z temi upokojenskimi plačami pa res si nea morš tega privoščit, </event>
      <event start="T120" end="T377-331">ne. </event>
      <event start="T377-331" end="T378-253">Ka praviš? </event>
      <event start="T378-253" end="T372">Ti bi ... </event>
      <event start="T372" end="T379-283">[smeh] </event>
      <event start="T379-283" end="T380-276">Tak da ... </event>
      <event start="T383-422" end="T385-334">Ja ja ja. </event>
      <event start="T387-639" end="T389-966">[nerazumljivo] Ja ja, ja seveda, </event>
      <event start="T389-966" end="T124">kaj boš te s totimi malimi evrčkami, </event>
      <event start="T124" end="T394-019">ne? </event>
      <event start="T394-019" end="T125">To je, to je fse skup premalo. </event>
      <event start="T125" end="T398-54">Ja, ja, ja. </event>
      <event start="T398-54" end="T399-631">Čuješ, </event>
      <event start="T399-631" end="T401-141">kak pa kaj tvoji vnukeci? </event>
      <event start="T402-016" end="T127">V redi? </event>
      <event start="T127" end="T404-35">Kok so že te stari? </event>
      <event start="T410-414" end="T411-615">Je že? </event>
      <event start="T417-235" end="T418-107">Mhm, </event>
      <event start="T418-107" end="T419-087">ja, sss. </event>
      <event start="T421-445" end="T135">Jezos, </event>
      <event start="T135" end="T136">kaj pa jaz, ko jih mam kar štiri, </event>
      <event start="T136" end="T137">ne samo [glas] dvej, </event>
      <event start="T137" end="T138">ne, </event>
      <event start="T138" end="T428-044">kar štiri jih mam. </event>
      <event start="T428-044" end="T431-789">Ema bo letos stara deset let. </event>
      <event start="T431-789" end="T139">Eee </event>
      <event start="T139" end="T435-831">Vid bo letos star trinajst let. </event>
      <event start="T435-831" end="T140">Od Tamare pa ... </event>
      <event start="T140" end="T441-411">Mia bo stara pet let. </event>
      <event start="T442-949" end="T141">Ja, </event>
      <event start="T141" end="T444-676">pet let. </event>
      <event start="T444-676" end="T143">Eee </event>
      <event start="T143" end="T450-726">moj najtamlajši Nikec pa bo star, </event>
      <event start="T450-726" end="T454-513">čez dva dni bo star deset mescov. </event>
      <event start="T455-815" end="T457-51">Pa veš, da mamo krst? </event>
      <event start="T458-377" end="T459-17">Ja. </event>
      <event start="T459-17" end="T144">Zaj, </event>
      <event start="T144" end="T461-151">soboto. </event>
      <event start="T461-151" end="T462-879">Dvandvajstiga. </event>
      <event start="T462-879" end="T146">Te pa bo naš ... se krstil. </event>
      <event start="T146" end="T147">Super! </event>
      <event start="T147" end="T470-266">Ne. </event>
      <event start="T470-266" end="T472-565">[premor] </event>
      <event start="T472-565" end="T148">Eee </event>
      <event start="T148" end="T373">tak da </event>
      <event start="T373" end="T374">bo, </event>
      <event start="T374" end="T475-911">bo veselo. </event>
      <event start="T475-911" end="T149">Družba, </event>
      <event start="T149" end="T477-377">ne. </event>
      <event start="T477-377" end="T150">Samo [glas] veš, </event>
      <event start="T150" end="T151">naredla bo pa v ožjem krogu, </event>
      <event start="T151" end="T482-283">ne. </event>
      <event start="T482-283" end="T485-038">Sej danes je to ... </event>
      <event start="T485-038" end="T486-134">Saj veš, kak je to danes, </event>
      <event start="T486-134" end="T152">ne. </event>
      <event start="T152" end="T488-331">Ja ja. </event>
      <event start="T488-331" end="T488-754">Saj ... </event>
      <event start="T488-754" end="T153">Pa pride pol prvi rojsn dan, </event>
      <event start="T153" end="T492-503">te pa de že kaj bol na več. </event>
      <event start="T492-503" end="T493-167">Tak da ... </event>
      <event start="T493-167" end="T494-928">[smeh] </event>
      <event start="T494-928" end="T496-039">Kaj pa t() ... </event>
      <event start="T496-039" end="T375">ka pa </event>
      <event start="T375" end="T376">eee </event>
      <event start="T376" end="T501-132">Lejla je praznovala kaj? </event>
      <event start="T507-128" end="T508-277">Vas je dosti blo? </event>
      <event start="T511-051" end="T378">Ha, </event>
      <event start="T378" end="T513-075">štrdeset? </event>
      <event start="T513-075" end="T515-082">Pa kaj si ti smešna. </event>
      <event start="T515-082" end="T159">To pa ni kar tak. </event>
      <event start="T159" end="T379">Ki ... </event>
      <event start="T379" end="T518-539">Ja. </event>
      <event start="T518-539" end="T519-608">Ki ste pa te bli? </event>
      <event start="T521-284" end="T521-995">A doma? </event>
      <event start="T521-995" end="T160">Tam pri Borisi, </event>
      <event start="T160" end="T524-793">ne? </event>
      <event start="T524-793" end="T525-836">Aha. </event>
      <event start="T525-836" end="T527-7">Ja, super. </event>
      <event start="T527-7" end="T161">Tej pa je b() ... </event>
      <event start="T161" end="T530-087">to pa je blo ... </event>
      <event start="T531-318" end="T533-137">A moje gibance ni blo? </event>
