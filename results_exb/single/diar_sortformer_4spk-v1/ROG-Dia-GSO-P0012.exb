      <event start="T1206-571" end="T1207-211">Aja? </event>
      <event start="T1207-641" end="T424">Ja, </event>
      <event start="T424" end="T1209-861">dobro. </event>
      <event start="T1209-861" end="T352">Ja, </event>
      <event start="T352" end="T1211-716">ni za kaj. </event>
      <event start="T1220-295" end="T358">Ja, </event>
