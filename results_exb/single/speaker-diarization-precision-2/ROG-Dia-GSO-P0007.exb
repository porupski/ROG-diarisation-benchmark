      <event start="T1732-421" end="T1733-451">mhm, mhm. </event>
      <event start="T1737-533" end="T1738-639">Ja. </event>
      <event start="T1739-296" end="T536">Joj, </event>
      <event start="T536" end="T537">[glas] ej, </event>
      <event start="T537" end="T538">jaz sem tako vesela, </event>
      <event start="T538" end="T1743-497">k si danes prišla. </event>
      <event start="T1744-448" end="T1747-507">Tako da ... [smeh] </event>
      <event start="T1747-507" end="T539">Ja. </event>
      <event start="T539" end="T540">Jaz predlagam, da midve greva kar zdajle po indukcijo </event>
      <event start="T540" end="T1752-243">pa jo damo v avto, </event>
